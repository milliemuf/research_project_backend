# CodeFlow AI - Environment Configuration
# Copy this to .env and fill in your values. NEVER commit a real .env.

# --- API keys for LLM providers (placeholders only — do not commit real keys) ---
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# Ollama configuration (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_MODEL=gpt-4o-mini

# --- Database configuration ---
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/codeflow
REDIS_URL=redis://localhost:6379/0

# --- Neo4j knowledge graph ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Application settings ---
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Consensus configuration ---
PBFT_FAULT_TOLERANCE=1
CONSENSUS_TIMEOUT_MS=5000
MIN_AGENTS_FOR_CONSENSUS=4

# --- Security ---
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
